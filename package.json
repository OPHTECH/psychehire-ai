{
  "name": "psychehire-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise psychological profiling and workforce intelligence SaaS platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "build": "npm run build -w packages/core && npm run build -w apps/api && npm run build -w apps/web",
    "test": "node tests/core.test.mjs",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}

